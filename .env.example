# ============================================
# MOTOMATE - YANDEX CLOUD CONFIGURATION
# ============================================
# Скопируй этот файл в .env и заполни свои значения

# 1. DATABASE CONFIGURATION
# Используется PostgreSQL 15 в Docker контейнере
POSTGRES_DB=motomate
POSTGRES_USER=motomate_user
POSTGRES_PASSWORD=your_strong_postgres_password_here_min_16_chars

# 2. APPLICATION SETTINGS
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_min_32_chars_change_this_in_production

# CORS Origins - список доменов, разрешённых для запросов
# Формат: https://example.com,https://app.example.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting: максимум запросов в минуту на пользователя
RATE_LIMIT_PER_MINUTE=120

# 3. YANDEX OAUTH
# Получи ключи на: https://oauth.yandex.ru
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# 4. YANDEX OBJECT STORAGE (S3-compatible)
# Инструкция получения ключей в YANDEX_SETUP.md

# Access Key ID из Яндекс.Облака
AWS_ACCESS_KEY_ID=your_yandex_access_key_id

# Secret Access Key из Яндекс.Облака  
AWS_SECRET_ACCESS_KEY=your_yandex_secret_access_key

# Имя бакета Object Storage (создать в консоли Яндекса)
S3_BUCKET=motomate-uploads

# Endpoint Яндекс Object Storage (не менять!)
S3_ENDPOINT=https://storage.yandex-cloud.net
AWS_REGION=ru-central1

# 5. YANDEX MAPS API
# Ключ для карт и геолокации
# Зарегистрируйся: https://developer.tech.yandex.ru/services/37
VITE_YANDEX_API_KEY=your_yandex_maps_api_key

# 6. FRONTEND CONFIGURATION
# URL API backend для фронтенда
VITE_API_URL=https://api.yourdomain.com

# 7. WEB PUSH NOTIFICATIONS (опционально)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
